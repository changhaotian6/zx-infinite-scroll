{
  "name": "zx-infinite-scroll",
  "version": "1.0.5",
  "description": "Vue 3 infinite scroll component with pull-to-refresh support",
  "main": "dist/index.umd.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "build:types": "vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch"
  },
  "keywords": [
    "vue3",
    "infinite-scroll",
    "pull-refresh",
    "list"
  ],
  "author": "changhaotian",
  "license": "MIT",
  "homepage": "https://github.com/changhaotian6/zx-infinite-scroll#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/changhaotian6/zx-infinite-scroll.git"
  },
  "bugs": {
    "url": "https://github.com/changhaotian6/zx-infinite-scroll/issues"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "sass": "^1.77.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.9.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
